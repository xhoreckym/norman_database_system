{
    "variable": [
        {
            "id": "baseUrl",
            "key": "baseUrl",
            "type": "string",
            "name": "string",
            "value": "http:\/\/127.0.0.1:8000"
        }
    ],
    "info": {
        "name": "Norman Database System",
        "_postman_id": "81c98a3e-c547-4296-ad7b-517fa4895082",
        "description": "",
        "schema": "https:\/\/schema.getpostman.com\/json\/collection\/v2.1.0\/collection.json"
    },
    "item": [
        {
            "name": "EMPODAT",
            "description": "\nAPIs for retrieving environmental monitoring data from the EMPODAT database.\nAll endpoints require authentication via Sanctum token.",
            "item": [
                {
                    "name": "Search EMPODAT by substance or country",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/v1\/empodat\/:search_type\/:search_value",
                            "query": [
                                {
                                    "key": "page",
                                    "value": "1",
                                    "description": "The page number for pagination.",
                                    "disabled": false
                                },
                                {
                                    "key": "per_page",
                                    "value": "100",
                                    "description": "Number of records per page (max 1000, default 100).",
                                    "disabled": false
                                }
                            ],
                            "raw": "{{baseUrl}}\/api\/v1\/empodat\/:search_type\/:search_value?page=1&per_page=100",
                            "variable": [
                                {
                                    "id": "search_type",
                                    "key": "search_type",
                                    "value": "substance",
                                    "description": "The type of search: \"substance\" or \"country\"."
                                },
                                {
                                    "id": "search_value",
                                    "key": "search_value",
                                    "value": "NS00000214",
                                    "description": "The search value. For substance: NS code (NS00000214) or InChIKey. For country: 2-letter ISO code (SK, DE)."
                                }
                            ]
                        },
                        "method": "GET",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application\/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": null,
                        "description": "Retrieve EMPODAT records by searching for a substance (NORMAN ID or InChIKey)\nor by country code. Results are paginated due to potentially large datasets."
                    },
                    "response": [
                        {
                            "header": [],
                            "code": 200,
                            "body": "{\n  \"data\": [\n    {\n      \"id\": 1,\n      \"sampling_date_year\": 2020,\n      \"concentration_value\": 0.0025,\n      \"substance\": {\"norman_id\": \"NS00004453\", \"name\": \"Sulfaclozine\"},\n      \"station\": {\"name\": \"Station A\", \"country\": {\"code\": \"SK\", \"name\": \"Slovakia\"}},\n      \"matrix\": {\"name\": \"Surface Water\"}\n    }\n  ],\n  \"links\": {\"first\": \"...\", \"last\": \"...\", \"prev\": null, \"next\": \"...\"},\n  \"meta\": {\"current_page\": 1, \"last_page\": 50, \"per_page\": 100, \"total\": 5000}\n}",
                            "name": "Success"
                        },
                        {
                            "header": [],
                            "code": 404,
                            "body": "{\n  \"success\": false,\n  \"message\": \"Substance not found\",\n  \"search_type\": \"substance\",\n  \"search_value\": \"NS99999999\"\n}",
                            "name": "Not Found"
                        },
                        {
                            "header": [],
                            "code": 422,
                            "body": "{\n  \"success\": false,\n  \"message\": \"Validation failed\",\n  \"errors\": {\"search_value\": [\"Substance must be a valid NORMAN ID or InChIKey.\"]}\n}",
                            "name": "Invalid Format"
                        }
                    ]
                }
            ]
        },
        {
            "name": "Substances",
            "description": "\nAPIs for retrieving substance data from the NORMAN Suspect List Exchange database.",
            "item": [
                {
                    "name": "Get substance by NORMAN ID",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/v1\/substances\/code\/:code",
                            "query": [],
                            "raw": "{{baseUrl}}\/api\/v1\/substances\/code\/:code",
                            "variable": [
                                {
                                    "id": "code",
                                    "key": "code",
                                    "value": "NS00004453",
                                    "description": "The NORMAN substance ID with NS prefix."
                                }
                            ]
                        },
                        "method": "GET",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application\/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"code\":\"NS75491716\"}"
                        },
                        "description": "Retrieve a substance using its NORMAN identifier (e.g., NS00004453).\nReturns comprehensive substance data including chemical identifiers,\nmolecular properties, categories, and sources.",
                        "auth": {
                            "type": "noauth"
                        }
                    },
                    "response": [
                        {
                            "header": [],
                            "code": 200,
                            "body": "{\n  \"data\": {\n    \"norman_id\": \"NS00004453\",\n    \"name\": \"Sulfaclozine\",\n    \"name_dashboard\": \"Sulfaclozine\",\n    \"name_iupac\": \"4-amino-N-(6-chloropyrazin-2-yl)benzenesulfonamide\",\n    \"cas_number\": \"102-65-8\",\n    \"smiles\": \"c1cc(ccc1N)S(=O)(=O)Nc2cncc(n2)Cl\",\n    \"stdinchi\": \"InChI=1S\/C10H9ClN4O2S\/...\",\n    \"stdinchikey\": \"QKLPUVXBJHRFQZ-UHFFFAOYSA-N\",\n    \"pubchem_cid\": \"66890\",\n    \"molecular_formula\": \"C10H9Cl1N4O2S1\",\n    \"monoisotopic_mass\": 284.013474,\n    \"status\": \"active\",\n    \"categories\": [{\"name\": \"Pharmaceuticals\", \"abbreviation\": \"PHAR\"}],\n    \"sources\": [{\"code\": \"S01\", \"name\": \"NORMAN SLE\"}]\n  }\n}",
                            "name": "Success"
                        },
                        {
                            "header": [],
                            "code": 404,
                            "body": "{\n  \"success\": false,\n  \"message\": \"Substance not found\",\n  \"code\": \"NS00004453\"\n}",
                            "name": "Not Found"
                        },
                        {
                            "header": [],
                            "code": 422,
                            "body": "{\n  \"success\": false,\n  \"message\": \"Validation failed\",\n  \"errors\": {\"code\": [\"The code must be in format NS followed by 8 digits (e.g., NS00004453).\"]}\n}",
                            "name": "Invalid Format"
                        }
                    ]
                },
                {
                    "name": "Get substance by InChIKey",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/v1\/substances\/inchikey\/:inchikey",
                            "query": [],
                            "raw": "{{baseUrl}}\/api\/v1\/substances\/inchikey\/:inchikey",
                            "variable": [
                                {
                                    "id": "inchikey",
                                    "key": "inchikey",
                                    "value": "QKLPUVXBJHRFQZ-UHFFFAOYSA-N",
                                    "description": "The Standard InChIKey."
                                }
                            ]
                        },
                        "method": "GET",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application\/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"inchikey\":\"EQMDLNGZOPRSWW-XXPMRXFVPO-N\"}"
                        },
                        "description": "Retrieve a substance using its Standard InChIKey identifier.\nThe InChIKey must be in the standard 27-character format (e.g., QKLPUVXBJHRFQZ-UHFFFAOYSA-N).",
                        "auth": {
                            "type": "noauth"
                        }
                    },
                    "response": [
                        {
                            "header": [],
                            "code": 200,
                            "body": "{\n  \"data\": {\n    \"norman_id\": \"NS00004453\",\n    \"name\": \"Sulfaclozine\",\n    \"stdinchikey\": \"QKLPUVXBJHRFQZ-UHFFFAOYSA-N\",\n    \"status\": \"active\"\n  }\n}",
                            "name": "Success"
                        },
                        {
                            "header": [],
                            "code": 404,
                            "body": "{\n  \"success\": false,\n  \"message\": \"Substance not found\",\n  \"inchikey\": \"QKLPUVXBJHRFQZ-UHFFFAOYSA-N\"\n}",
                            "name": "Not Found"
                        },
                        {
                            "header": [],
                            "code": 422,
                            "body": "{\n  \"success\": false,\n  \"message\": \"Validation failed\",\n  \"errors\": {\"inchikey\": [\"The InChIKey must be in valid format (e.g., QKLPUVXBJHRFQZ-UHFFFAOYSA-N).\"]}\n}",
                            "name": "Invalid Format"
                        }
                    ]
                }
            ]
        }
    ],
    "auth": {
        "type": "bearer",
        "bearer": [
            {
                "key": "Authorization",
                "type": "string"
            }
        ]
    }
}